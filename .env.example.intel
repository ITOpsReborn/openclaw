# Example Docker env for OpenClaw with Intel Arc / Intel iGPU acceleration on Linux or WSL2.
# Copy to .env and adjust paths/ports/group IDs for your host.
#
# This file is intended for use with:
#   docker build --build-arg OPENCLAW_INSTALL_INTEL_GPU=1 -t openclaw:intel-gpu .
#   docker compose --profile intel-gpu up -d openclaw-gateway-intel-gpu
#
# Notes:
# - OPENCLAW_IMAGE must point at the Intel-enabled image you built.
# - OPENCLAW_GPU_BACKEND=intel tells the Gateway to request Intel GPU acceleration.
# - RENDER_GID / VIDEO_GID must match your host /dev/dri device group IDs.
#   Check with:
#     stat -c '%g' /dev/dri/renderD128
#     stat -c '%g' /dev/dri/card0
# - Persistent secrets for providers usually live in ~/.openclaw/.env, not here.

# -----------------------------------------------------------------------------
# Docker image + Intel GPU mode
# -----------------------------------------------------------------------------
OPENCLAW_IMAGE=openclaw:intel-gpu
OPENCLAW_GPU_BACKEND=intel

# Host /dev/dri group IDs for the intel-gpu compose profile.
# Replace these with values from your host if different.
RENDER_GID=109
VIDEO_GID=44

# -----------------------------------------------------------------------------
# Gateway network + auth
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_MSTEAMS_PORT=3978
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=

# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-with-a-real-token

# -----------------------------------------------------------------------------
# Host-mounted persistent state
# -----------------------------------------------------------------------------
# Linux example:
OPENCLAW_CONFIG_DIR=/home/YOUR_USER/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/YOUR_USER/.openclaw/workspace
OPENCLAW_AUTH_PROFILE_SECRET_DIR=/home/YOUR_USER/.openclaw-auth-profile-secrets

# WSL2 example (uncomment and edit instead of the Linux paths above):
# OPENCLAW_CONFIG_DIR=/home/YOUR_USER/.openclaw
# OPENCLAW_WORKSPACE_DIR=/home/YOUR_USER/.openclaw/workspace
# OPENCLAW_AUTH_PROFILE_SECRET_DIR=/home/YOUR_USER/.openclaw-auth-profile-secrets

# Optional timezone for logs/runtime behavior.
OPENCLAW_TZ=UTC

# -----------------------------------------------------------------------------
# Optional Docker image build customization
# -----------------------------------------------------------------------------
# Extra apt packages baked into the image.
# OPENCLAW_IMAGE_APT_PACKAGES=ffmpeg jq

# Extra Python packages baked into the image.
# OPENCLAW_IMAGE_PIP_PACKAGES=requests==2.32.5

# Pre-install Chromium for browser automation.
# OPENCLAW_INSTALL_BROWSER=1

# Optional bundled extensions to include.
# OPENCLAW_EXTENSIONS=

# -----------------------------------------------------------------------------
# Optional telemetry / advanced settings
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=
# OTEL_SEMCONV_STABILITY_OPT_IN=
# OPENCLAW_OTEL_PRELOADED=

# Optional Claude session env passthrough.
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=
